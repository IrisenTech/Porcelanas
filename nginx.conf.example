##
## Nginx configuration for Porcelanas VPS deployment
## Place this file at: /etc/nginx/sites-available/porcelanas
## Then: ln -s /etc/nginx/sites-available/porcelanas /etc/nginx/sites-enabled/
## Then: nginx -t && systemctl reload nginx
##

server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    # Redirect HTTP → HTTPS (uncomment after getting SSL cert via certbot)
    # return 301 https://$host$request_uri;

    root /var/www/porcelanas;
    index index.html;

    # ── Gzip compression ──────────────────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        image/svg+xml;

    # ── Static assets (JS/CSS/images) — long cache ────────────────────────
    location ~* \.(js|css|webp|png|jpg|jpeg|svg|ico|woff2|woff)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        add_header Vary "Accept-Encoding";
        try_files $uri =404;
    }

    # ── API proxy → backend (port 3001) ───────────────────────────────────
    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Limit request size for PDF uploads
        client_max_body_size 15M;
    }

    # ── SPA fallback — all routes → index.html ────────────────────────────
    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache";
    }

    # ── Security headers ─────────────────────────────────────────────────
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}

# ── HTTPS block (uncomment after: certbot --nginx -d yourdomain.com) ────────
